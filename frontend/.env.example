# Copiá este archivo como .env y ajustá los valores para tu entorno.

# Puerto donde corre la API .NET en desarrollo local (dotnet run)
# Verificalo con: dotnet run --project src/AcademicPlanner.API (el puerto aparece en el log)
API_PORT=5115

# Solo necesario si el proxy de Vite no se usa (ej: build de producción contra Docker)
# Ejemplo Docker: VITE_API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=
